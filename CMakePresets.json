{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "default",
            "inherits": "base",
            "displayName": "System / PATH find_package",
            "description": "Resolve dependencies via CMAKE_PREFIX_PATH and system find_package; falls back to FetchContent."
        },
        {
            "name": "vcpkg",
            "inherits": "base",
            "displayName": "vcpkg toolchain",
            "description": "Resolve dependencies via vcpkg. Requires VCPKG_ROOT to be set in the environment.",
            "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
        },
        {
            "name": "conan",
            "inherits": "base",
            "displayName": "Conan 2 toolchain",
            "description": "Resolve dependencies via Conan 2. Run `conan install . -of build/conan --build=missing` first.",
            "toolchainFile": "${sourceDir}/build/conan/conan_toolchain.cmake"
        },
        {
            "name": "debug",
            "inherits": "default",
            "displayName": "Debug build (system)",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "debug-cached",
            "inherits": "debug",
            "displayName": "Debug build (shared FetchContent cache)",
            "description": "Debug build that reuses a shared FetchContent download/build cache across presets to avoid re-fetching dependencies.",
            "cacheVariables": {
                "FETCHCONTENT_BASE_DIR": "$env{HOME}/.cache/cmake-fetchcontent"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "vcpkg",
            "configurePreset": "vcpkg"
        },
        {
            "name": "conan",
            "configurePreset": "conan"
        },
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "debug-cached",
            "configurePreset": "debug-cached"
        }
    ],
    "testPresets": [
        {
            "name": "default",
            "configurePreset": "default",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "stopOnFailure": false
            }
        },
        {
            "name": "vcpkg",
            "configurePreset": "vcpkg",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "stopOnFailure": false
            }
        },
        {
            "name": "conan",
            "configurePreset": "conan",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "stopOnFailure": false
            }
        },
        {
            "name": "debug",
            "configurePreset": "debug",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "stopOnFailure": false
            }
        },
        {
            "name": "debug-cached",
            "configurePreset": "debug-cached",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "stopOnFailure": false
            }
        }
    ]
}